{
  "_comment": "DeepSpeed ZeRO-3 配置 —— 4× RTX 3060 20GB（PCIe，无 NVLink），BF16，LoRA",
  "_comment_zero3": [
    "ZeRO-3 同时分片参数/梯度/优化器状态，适合显存受限多卡场景。",
    "核心权衡：per-GPU 显存 ↓，但 allgather 通信量 ↑，PCIe 带宽是瓶颈。",
    "建议：bucket_size 调小以减少单次通信峰值显存；overlap_comm 让通信与计算并行。"
  ],

  "train_batch_size": "auto",
  "train_micro_batch_size_per_gpu": "auto",
  "gradient_accumulation_steps": "auto",

  "bf16": {
    "enabled": true
  },
  "fp16": {
    "enabled": false
  },

  "zero_optimization": {
    "stage": 3,

    "overlap_comm": true,
    "contiguous_gradients": true,
    "reduce_scatter": true,

    "reduce_bucket_size":    5e7,
    "prefetch_bucket_size":  5e7,
    "param_persistence_threshold": 1e5,

    "stage3_max_live_parameters":  1e9,
    "stage3_max_reuse_distance":   1e9,
    "stage3_gather_16bit_weights_on_model_save": true,

    "offload_optimizer": {
      "device": "cpu",
      "pin_memory": true
    },
    "offload_param": {
      "device": "none"
    }
  },

  "gradient_clipping": 1.0,
  "steps_per_print": 50,
  "wall_clock_breakdown": false
}
