# Fitness Coach 配置文件示例
# 将此文件改名为 .env，并根据需要修改参数
#
# 推理由独立的 SGLang server 进程承载（见 scripts/launch_sglang.sh），
# 量化 / 精度 / FlashAttention / 多卡并行等参数都在 server 启动时配置，
# 本文件中不再涉及。

# ============================================================================
# SGLang 服务连接
# ============================================================================

# SGLang server 地址（默认 launch_server 监听 30000）
SGLANG_ENDPOINT=http://127.0.0.1:30000

# 单次请求超时（秒）。多帧 + 多轮 agentic 时建议 ≥ 120
SGLANG_TIMEOUT=300

# 与 SGLang server 启动时 --model-path 必须一致
VLM_MODEL_NAME=Qwen/Qwen3-VL-8B-Instruct

# ============================================================================
# 模型缓存（仅 download_model.py 使用；SGLang server 也读同一缓存）
# ============================================================================

# Hugging Face 端点（中国大陆可用: https://hf-mirror.com）
HF_ENDPOINT=

# 模型缓存目录
HF_HOME=

# ============================================================================
# 生成参数
# ============================================================================

# 单轮最大生成 token（agentic 多轮建议 ≥ 512）
VLM_MAX_TOKENS=512

# 发给 VLM 的最大帧数（从录制帧中按 FRAME_SAMPLING_STRATEGY 抽取）
VLM_MAX_FRAMES=8

# 抽帧策略：
#   phase_anchored（默认）— 用 MediaPipe 关节角度极值锚定 起始/底部/顶点/结束，剩余按间隔比例补
#   uniform              — 旧版均匀抽帧基线（mediapipe 不可用时也会自动退化到此）
FRAME_SAMPLING_STRATEGY=phase_anchored

# 采样策略
VLM_DO_SAMPLE=1
VLM_TEMPERATURE=0.6
VLM_TOP_P=0.9
VLM_REPETITION_PENALTY=1.05

# ============================================================================
# Agentic loop
# ============================================================================

# 最大迭代轮数（超出后强制返回最后一轮输出）
AGENT_MAX_ITER=3

# ============================================================================
# 视频流配置
# ============================================================================

CAMERA_ID=0

# 摄像头后端（auto/dshow/msmf/ffmpeg/gstreamer）
CAMERA_BACKEND=auto

# 帧缓冲队列大小
BUFFER_SIZE=15

# 采样率（每 SAMPLE_RATE 帧采 1 帧）
SAMPLE_RATE=10

# 短边缩放目标像素
TARGET_HEIGHT=336

# 摄像头帧率
VIDEO_FPS=30

CAMERA_READ_FAIL_WARN_INTERVAL=1.0

# 按 S 后延迟开始录制（秒）
PRE_RECORD_DELAY=5.0

# 录制时长（秒）
RECORD_DURATION=10.0

# ============================================================================
# UI 配置
# ============================================================================

# 反馈文本显示时长（秒）
FEEDBACK_DURATION=4.0

# 是否启用详细日志
VERBOSE=True
