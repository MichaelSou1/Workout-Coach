# Fitness Coach 配置文件示例
# 将此文件改名为 .env，并根据需要修改参数

# ============================================================================
# VLM 模型配置
# ============================================================================

# Hugging Face 模型名称
VLM_MODEL_NAME=Qwen/Qwen2-VL-2B-Instruct

# 离线模式：1=仅使用本地缓存，不发起网络请求
VLM_LOCAL_FILES_ONLY=0

# Hugging Face 端点（中国大陆可用: https://hf-mirror.com）
# 留空表示使用官方默认 https://huggingface.co
HF_ENDPOINT=

# 模型缓存目录（建议用于离线部署）
# 例如：C:/Users/<YourName>/Desktop/Workout-Coach/hf_cache
HF_HOME=

# 网络不稳定时建议关闭 hf_transfer（0=关闭，1=开启）
HF_HUB_ENABLE_HF_TRANSFER=0

# 全局离线开关（离线运行时可设为 1）
HF_HUB_OFFLINE=0
HF_DATASETS_OFFLINE=0

# 推理设备
VLM_DEVICE=cuda

# 生成的最大 token 数
VLM_MAX_TOKENS=256

# 发给 VLM 的最大帧数（从录制帧中均匀抽取，2B 模型建议 6-10）
VLM_MAX_FRAMES=8

# 生成策略
VLM_DO_SAMPLE=1
VLM_TEMPERATURE=0.6
VLM_TOP_P=0.9
VLM_REPETITION_PENALTY=1.05

# ============================================================================
# 视频流配置
# ============================================================================

# 摄像头 ID（0 为默认前置摄像头）
CAMERA_ID=0

# 摄像头后端（auto/dshow/msmf/ffmpeg/gstreamer）
# Windows 建议优先 dshow，可减少 MSMF 的 grabFrame 报错
CAMERA_BACKEND=auto

# 帧缓冲队列大小（越大越占显存）
BUFFER_SIZE=15

# 采样率（每 SAMPLE_RATE 帧采 1 帧，越高越省显存）
SAMPLE_RATE=10

# 短边缩放目标像素（横竖屏均按短边缩放，越小越省显存）
TARGET_HEIGHT=336

# 摄像头帧率
VIDEO_FPS=30

# 读取帧失败时日志限频间隔（秒）
CAMERA_READ_FAIL_WARN_INTERVAL=1.0

# 按 S 后延迟开始录制（秒）
PRE_RECORD_DELAY=5.0

# 录制时长（秒，建议 >=10）
RECORD_DURATION=10.0

# ============================================================================
# UI 配置
# ============================================================================

# 反馈文本显示时长（秒）
FEEDBACK_DURATION=4.0

# 是否启用详细日志
VERBOSE=True

# 是否启用 Flash Attention 2（降低显存）
USE_FLASH_ATTENTION_2=True
